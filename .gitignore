# BookOS Git Ignore Configuration

# System Files
.DS_Store
Thumbs.db
*.log
*.tmp

# Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# BookOS Output & Build folders
# Ignore built files and releases, track only source drafts and framework configs
Releases/
Build/
Audits/

# Temp/Scratch files
scratch/
temp/
tmp/

# Python files
__pycache__/
*.pyc
.venv*/

# Backup files
backups_*/

# Author-private simulator files (never commit to public git)
Simulator/Private/
Simulator/private/



